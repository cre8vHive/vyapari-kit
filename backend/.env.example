PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:password@cluster.example.net/vyapari-kit?retryWrites=true&w=majority
AUTH_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGINS=http://localhost:5173
ADMIN_EMAILS=admin@example.com
JSON_BODY_LIMIT=15mb
MAX_PDF_UPLOAD_BYTES=15728640
PDF_ALLOWED_HOSTNAMES=storage.example.com,*.trusted-cdn.example.com
EXTERNAL_PDF_FETCH_TIMEOUT_MS=10000
TRUST_PROXY_HOPS=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
PDF_RATE_LIMIT_MAX=120
